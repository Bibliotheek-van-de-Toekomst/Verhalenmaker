# Verhaalmaker — environment variables template
# Kopieer naar .env.local en vul in. COMMIT .env.local NOOIT.
# Minstens één AI-provider is verplicht; meer mag.

# AI-providers (alleen goedkope modellen, geen reasoning)
ANTHROPIC_API_KEY=sk-ant-...          # Claude Haiku 4.5
OPENAI_API_KEY=sk-...                 # GPT-4.1 mini
MISTRAL_API_KEY=...                   # Mistral Small / Ministral 8B

# Optioneel: beperk welke modellen leerlingen zien in de selector.
# Laat leeg om ALLE beschikbare modellen te tonen.
# Waardes: claude-haiku-4-5, gpt-4-1-mini, mistral-small, ministral-8b
LMC_TOEGESTANE_MODELLEN=

# Optioneel: welk model voorgeselecteerd is bij eerste bezoek.
STANDAARD_MODEL=claude-haiku-4-5
